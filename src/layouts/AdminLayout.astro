---
import Sidebar from '../components/admin/Sidebar.astro';
import Topbar from '../components/admin/Topbar.astro';

interface Props {
  title: string;
  description?: string;
  userEmail?: string;
}

const { title, description = "Panel de Administración", userEmail } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <!-- Google Fonts: Space Grotesk y IBM Plex Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <Sidebar />
    <main class="content">
      <Topbar title={title} userEmail={userEmail} />
      <div class="page-content">
        <slot />
      </div>
    </main>
  </div>

  <style is:global>
    :root {
      --bg-dark: #221010; /* Deep Oxblood */
      --bg-light: #f8f5f5; /* Paper White */
      --primary: #f20d0d; /* Atomic Red */
      
      --panel-bg: var(--bg-dark); 
      --panel-border: #f8f5f5; /* Borde visible y duro */
      --text-main: #f8f5f5;
      --text-muted: #8a8a8a;
      --danger: #f20d0d;
      --success: #10B981;
      
      --font-heading: 'Space Grotesk', sans-serif;
      --font-body: 'Space Grotesk', sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      margin: 0;
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      letter-spacing: -0.02em;
      text-transform: uppercase;
      font-weight: 700;
    }

    * {
      box-sizing: border-box;
    }

    /* Eliminado .glass-panel para apegarse al brutalismo */

    /* Utilitarios globales para Admin */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 2px;
      font-family: var(--font-mono);
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: none; /* Inversión instantánea según DESIGN.md */
      text-decoration: none;
      border: 1px solid var(--panel-border);
    }

    .btn-primary {
      background: var(--primary);
      color: var(--text-main);
      border-color: var(--primary);
    }
    .btn-primary:hover {
      background: var(--bg-dark);
      color: var(--primary);
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-main);
      border-color: var(--panel-border);
    }
    .btn-secondary:hover {
      background: var(--text-main);
      color: var(--bg-dark);
    }

    .btn-danger {
      background: transparent;
      color: var(--danger);
      border: 1px solid var(--danger);
    }
    .btn-danger:hover {
      background: var(--danger);
      color: var(--text-main);
    }

    /* Layout Estructural */
    .admin-layout {
      display: flex;
      min-height: 100vh;
    }

    .content {
      flex: 1;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow-y: auto;
    }

    .page-content {
      padding: 0 3rem 3rem 3rem;
      flex: 1;
    }

    /* Scrollbar crudo */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg-dark);
      border-left: 1px solid var(--panel-border);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--panel-border);
      border-radius: 0;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--primary);
    }

  </style>
</body>
</html>
