---

---

<section
  class="w-full flex flex-col md:flex-row bg-white dark:bg-background-dark"
>
  <!-- Instagram Block -->
  <a
    href="https://instagram.com"
    target="_blank"
    class="w-full md:w-1/2 p-16 flex flex-col items-center justify-center brutal-border-b md:brutal-border-b-0 md:brutal-border-r group hover:bg-primary transition-colors duration-300"
  >
    <span
      class="text-sm font-mono uppercase tracking-[0.3em] mb-4 group-hover:text-white dark:text-white"
      >Seguir en</span
    >
    <h2
      class="text-5xl md:text-7xl font-black uppercase group-hover:text-white dark:text-white"
    >
      INSTAGRAM
    </h2>
    <span
      class="mt-8 text-2xl group-hover:translate-x-4 transition-transform group-hover:text-white dark:text-white"
      >→</span
    >
  </a>

  <!-- WhatsApp/Direct Block -->
  <a
    href="https://wa.me/something"
    target="_blank"
    class="w-full md:w-1/2 p-16 flex flex-col items-center justify-center group hover:bg-black dark:hover:bg-white transition-colors duration-300"
  >
    <span
      class="text-sm font-mono uppercase tracking-[0.3em] mb-4 group-hover:text-white dark:group-hover:text-black dark:text-white"
      >Consulta Directa</span
    >
    <h2
      class="text-5xl md:text-7xl font-black uppercase group-hover:text-white dark:group-hover:text-black dark:text-white"
    >
      WHATSAPP
    </h2>
    <span
      class="mt-8 text-2xl group-hover:-translate-y-4 transition-transform group-hover:text-white dark:group-hover:text-black dark:text-white"
      >↑</span
    >
  </a>
</section>

<footer
  class="w-full p-8 brutal-border-t bg-black text-white dark:bg-white dark:text-black flex flex-col md:flex-row justify-between items-center gap-8"
>
  <div class="font-black text-2xl uppercase tracking-tighter">
    CONFECCIONARTE
  </div>
  <div
    class="font-mono text-[10px] opacity-60 uppercase text-center md:text-right"
  >
    Basado en principios de arquitectura textil // © 2026 Todos los derechos
    reservados.<br />
    Hecho para durar.
  </div>
</footer>
