---
import { supabase } from "../lib/supabase";

const { data: categories, error } = await supabase
    .from("categories")
    .select("*")
    .order("name");

if (error) {
    console.error("Error fetching categories:", error);
}

// Mapeo dinámico de bordes basado en el índice para mantener el diseño brutalista
const getBorders = (index: number) => {
    switch (index) {
        case 0:
            return "brutal-border-b xl:brutal-border-b-0 brutal-border-r";
        case 1:
            return "brutal-border-b xl:brutal-border-b-0 md:brutal-border-r";
        case 2:
            return "brutal-border-b md:brutal-border-b-0 xl:brutal-border-r";
        default:
            return "";
    }
};

const displayCategories =
    categories?.map((category, index) => ({
        title: category.name,
        image: category.image_url,
        href: `/catalogo?categoria=${category.slug}`,
        borders: getBorders(index),
    })) || [];
---

<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 w-full">
    {
        displayCategories.map((category) => (
            <a
                class={`group relative flex flex-col h-[512px] md:h-[614px] hover-invert overflow-hidden cursor-pointer block bg-white dark:bg-background-dark transition-colors duration-300 ${category.borders}`}
                href={category.href}
            >
                <div class="flex-grow w-full bg-gray-100 dark:bg-[#1a1a1a] relative">
                    <img
                        alt={category.title}
                        class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-none"
                        src={category.image}
                    />
                </div>
                <div class="h-[80px] w-full flex items-center justify-center brutal-border-t px-4">
                    <h3 class="text-2xl font-black tracking-tight uppercase group-hover:text-white dark:text-white">
                        {category.title}
                    </h3>
                </div>
            </a>
        ))
    }
</section>
