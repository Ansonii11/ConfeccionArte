---
import { getSupabase } from "../lib/supabaseServer";
import ProductCard from "./ProductCard.astro";

const supabase = getSupabase(Astro.cookies);

// Obtenemos 4 productos destacados con sus imágenes
const { data: products, error } = await supabase
    .from("products")
    .select(`
        *,
        product_images (
            storage_path,
            is_primary
        )
    `)
    .eq("featured", true)
    .eq("status", "active")
    .limit(4);

if (error) {
    console.error("Error fetching featured products:", error);
}

const featuredProducts = products?.map(product => {
    const primaryImg = product.product_images.find(img => img.is_primary)?.storage_path || product.product_images[0]?.storage_path;
    const secondaryImg = product.product_images.find(img => !img.is_primary)?.storage_path || primaryImg;
    
    return {
        ...product,
        imagePrimary: primaryImg,
        imageSecondary: secondaryImg
    };
}) || [];
---

{featuredProducts.length > 0 && (
    <section class="w-full brutal-border-b">
        <div class="p-8 brutal-border-b bg-black dark:bg-white">
            <h2 class="text-4xl md:text-5xl font-black text-white dark:text-black uppercase tracking-tighter">
                Selección Curada // Novedades
            </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 w-full featured-grid">
            {featuredProducts.map((product) => (
                <div class="featured-card-wrapper">
                    <ProductCard
                        title={product.name}
                        price={`$${product.price}`}
                        sku={product.sku || "N/A"}
                        slug={product.slug}
                        imagePrimary={product.imagePrimary}
                        imageSecondary={product.imageSecondary}
                    />
                </div>
            ))}
        </div>
    </section>
)}

<style>
    .featured-card-wrapper {
        opacity: 0;
        transform: scale(0.95);
        transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .revealed .featured-card-wrapper {
        opacity: 1;
        transform: scale(1);
    }

    .featured-card-wrapper:nth-child(1) { transition-delay: 0.1s; }
    .featured-card-wrapper:nth-child(2) { transition-delay: 0.2s; }
    .featured-card-wrapper:nth-child(3) { transition-delay: 0.3s; }
    .featured-card-wrapper:nth-child(4) { transition-delay: 0.4s; }
</style>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
            }
        });
    }, { threshold: 0.1 });

    const grid = document.querySelector('.featured-grid');
    if (grid) {
        observer.observe(grid);
    }
</script>
