---
interface Props {
    id: string;
    title: string;
    price: string;
    sku: string;
    slug: string;
    imagePrimary: string;
    imageSecondary: string;
    soldOut?: boolean;
}

const {
    id,
    title,
    price,
    sku,
    slug,
    imagePrimary,
    imageSecondary,
    soldOut = false,
} = Astro.props;
---

<a
    href={`/producto/${slug}`}
    data-product-id={id}
    class={`product-card flex flex-col aspect-square brutal-border-r brutal-border-b lg:last:border-r-0 cursor-pointer group ${soldOut ? "opacity-80 pointer-events-none" : ""}`}
>
    <article
        class="h-full flex flex-col bg-white dark:bg-background-dark transition-colors duration-300"
    >
        <!-- Image Area (85%) -->
        <div
            class="h-[85%] w-full bg-[#f4f4f4] dark:bg-[#1a1a1a] relative overflow-hidden transition-colors duration-300"
        >
            <div
                class={`absolute top-4 left-4 z-10 ${soldOut ? "bg-primary" : "bg-black dark:bg-white"} ${soldOut ? "text-white" : "text-white dark:text-black"} px-2 py-1 font-mono text-[10px]`}
            >
                {soldOut ? "AGOTADO" : `SKU: ${sku}`}
            </div>

            <img
                alt={title}
                class="img-primary w-full h-full object-cover object-center grayscale contrast-125 mix-blend-multiply dark:mix-blend-normal group-hover:hidden"
                src={imagePrimary}
            />
            <img
                alt={`${title} detalle`}
                class="img-secondary hidden w-full h-full object-cover object-center grayscale contrast-125 mix-blend-multiply dark:mix-blend-normal group-hover:block"
                src={imageSecondary}
            />
        </div>

        <!-- Details Area (15%) -->
        <div
            class={`h-[15%] w-full flex brutal-border-t transition-none ${soldOut ? "bg-[#f4f4f4] dark:bg-[#1a1a1a] text-[#8a8a8a]" : "group-hover:bg-black group-hover:text-white dark:group-hover:bg-white dark:group-hover:text-black"}`}
        >
            <div
                class={`w-3/4 p-4 flex items-center brutal-border-r ${soldOut ? "border-gray-400" : "group-hover:border-white dark:group-hover:border-black"}`}
            >
                <h2
                    class={`font-heading text-lg lg:text-xl truncate text-black dark:text-white ${soldOut ? "line-through text-[#8a8a8a]" : "group-hover:text-white dark:group-hover:text-black"}`}
                >
                    {title}
                </h2>
            </div>
            <div class="w-1/4 p-4 flex items-center justify-center">
                <span
                    class={`font-mono text-sm font-bold text-black dark:text-white ${soldOut ? "line-through text-[#8a8a8a]" : "group-hover:text-white dark:group-hover:text-black"}`}
                >
                    {price}
                </span>
            </div>
        </div>
    </article>
</a>

<script>
    // Seleccionar todos los links de productos
    const productLinks = document.querySelectorAll('.product-card');

    productLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            const productId = link.getAttribute('data-product-id');
            if (productId) {
                // Usamos fetch con 'keepalive' para asegurar que la petición se complete aunque la página cambie
                fetch('/api/track-click', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId }),
                    keepalive: true
                }).catch(err => console.error('Error tracking click:', err));
            }
        });
    });
</script>
