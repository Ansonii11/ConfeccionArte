---
// Redirección de compatibilidad: de /producto?slug=xxx a /producto/xxx
const slug = Astro.url.searchParams.get("slug");

if (slug) {
    return Astro.redirect(`/producto/${slug}`);
} else {
    return Astro.redirect("/catalogo");
}
---
<html>
    <head>
        <title>Redirigiendo...</title>
    </head>
    <body style="background: white; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: sans-serif;">
        <p>Cargando producto...</p>
    </body>
</html>
