---

<MainLayout title="Maison Brut - Catálogo">
    <NavBar />

    <main class="pt-[80px] flex-grow flex flex-col w-full">
        <div class="flex flex-col lg:flex-row flex-1 w-full relative">
            <!-- Mobile Filter Toggle -->
            <div
                class="lg:hidden p-4 brutal-border-b flex justify-between items-center bg-[#f4f4f4]"
            >
                <span class="font-mono text-xs font-bold uppercase"
                    >FILTROS / NAVEGACIÓN</span
                >
                <span
                    class="material-symbols-outlined cursor-pointer hover:text-primary"
                    >tune</span
                >
            </div>

            <!-- Sidebar Component -->
            <CatalogSidebar />

            <!-- Content Area -->
            <section class="w-full lg:w-[80vw] flex flex-col bg-white">
                <!-- Oversized Header -->
                <div
                    class="w-full px-6 py-12 md:py-20 brutal-border-b bg-[#f4f4f4] flex flex-col justify-end min-h-[307px]"
                >
                    <span
                        class="font-mono text-xs text-[#8a8a8a] mb-4 block uppercase font-bold tracking-widest"
                    >
                        MOSTRANDO {products.length} RESULTADOS / ABRIGOS
                    </span>
                    <h1
                        class="text-6xl md:text-8xl lg:text-[120px] leading-none font-black text-black m-0 p-0 break-words uppercase tracking-tighter"
                    >
                        CATÁLOGO
                    </h1>
                </div>

                <!-- Product Grid -->
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full border-t-0 border-l-0"
                >
                    {products.map((product) => <ProductCard {...product} />)}
                    <!-- Repeat for layout demonstration -->
                    {products.map((product) => <ProductCard {...product} />)}
                    {products.map((product) => <ProductCard {...product} />)}
                </div>

                <!-- Footer / Loading Area -->
                <div
                    class="w-full py-16 flex justify-center items-center bg-white brutal-border-b"
                >
                    <span
                        class="font-mono text-sm text-[#8a8a8a] tracking-[0.2em] font-bold uppercase"
                    >
                        [ CARGANDO MÁS ESTRUCTURAS ]
                    </span>
                </div>
            </section>
        </div>
    </main>
</MainLayout>
