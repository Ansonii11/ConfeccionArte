---
import MainLayout from "../layouts/MainLayout.astro";
import NavBar from "../components/NavBar.astro";
import CatalogSidebar from "../components/CatalogSidebar.astro";
import ProductCard from "../components/ProductCard.astro";
import { supabase } from "../lib/supabase";

const categorySlug = Astro.url.searchParams.get("categoria");
const currentSize = Astro.url.searchParams.get("talla");

let query = supabase.from("products").select(
  `
        *,
        product_images (
            storage_path,
            is_primary
        )${currentSize ? ',\n        product_variants!inner(size)' : ''}
    `
);

if (categorySlug) {
  const { data: category } = await supabase
    .from("categories")
    .select("id")
    .eq("slug", categorySlug)
    .single();

  if (category) {
    query = query.eq("category_id", category.id);
  }
}

if (currentSize) {
  query = query.eq("product_variants.size", currentSize);
}

const { data: rawProducts, error } = await query.order("created_at", {
  ascending: false,
});

if (error) {
  console.error("Error fetching products:", error);
}

const PLACEHOLDER_IMAGE =
  "https://placehold.co/600x800/f4f4f4/1a1a1a?text=Próximamente";

const products =
  rawProducts?.map((p: any) => {
    const primaryImg =
      p.product_images?.find((img: any) => img.is_primary) ||
      p.product_images?.[0];
    
    const secondaryImg = 
      p.product_images?.find((img: any) => !img.is_primary) || 
      primaryImg;

    const getUrl = (path: string) => 
      path ? supabase.storage.from("products").getPublicUrl(path).data.publicUrl : PLACEHOLDER_IMAGE;

    return {
      id: p.id,
      title: p.name,
      price: `$${p.price}`,
      sku: p.sku,
      slug: p.slug,
      imagePrimary: getUrl(primaryImg?.storage_path),
      imageSecondary: getUrl(secondaryImg?.storage_path),
    };
  }) || [];
---

<MainLayout 
  title="Catálogo de Estructuras y Moda | ConfeccionArte"
  description="Explora nuestra colección de ropa personalizada, artículos de regalo, bisutería y más. Piezas únicas confeccionadas con arte."
>
  <NavBar />

  <main class="pt-[80px] flex-grow flex flex-col w-full">
    <div
      class="flex flex-col lg:flex-row flex-1 w-full relative bg-white dark:bg-background-dark"
    >
      <!-- Mobile Filter Toggle -->
      <div
        id="filter-toggle"
        class="lg:hidden p-4 brutal-border-b flex justify-between items-center bg-[#f4f4f4] dark:bg-[#1a1a1a] transition-colors duration-300 cursor-pointer group"
      >
        <span
          class="font-mono text-xs font-bold uppercase text-black dark:text-white group-hover:text-primary"
          >FILTROS / NAVEGACIÓN</span
        >
        <svg class="size-5 dark:text-white group-hover:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
        </svg>
      </div>

      <!-- Sidebar Component -->
      <CatalogSidebar />

      <!-- Content Area -->
      <section
        class="w-full lg:w-[80vw] flex flex-col bg-white dark:bg-background-dark"
      >
        <!-- Oversized Header -->
        <div
          class="w-full px-6 py-12 md:py-20 brutal-border-b bg-[#f4f4f4] dark:bg-[#1a1a1a] flex flex-col justify-end min-h-[307px] transition-colors duration-300"
        >
          <span
            class="font-mono text-xs text-[#8a8a8a] dark:text-gray-400 mb-4 block uppercase font-bold tracking-widest"
          >
            MOSTRANDO {products.length} RESULTADOS {
              categorySlug ? `/ ${categorySlug}` : ""
            }
          </span>
          <h1
            class="text-6xl md:text-8xl lg:text-[120px] leading-none font-black text-black dark:text-white m-0 p-0 break-words uppercase tracking-tighter"
          >
            {categorySlug || "CATÁLOGO"}
          </h1>
        </div>

        <!-- Product Grid -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full border-t-0 border-l-0 bg-white dark:bg-background-dark"
        >
          {products.map((product) => <ProductCard {...product} />)}
        </div>

        <!-- Footer / Loading Area -->
        <div
          class="w-full py-16 flex justify-center items-center bg-white dark:bg-background-dark brutal-border-b transition-colors duration-300"
        >
          <span
            class="font-mono text-sm text-[#8a8a8a] dark:text-gray-400 tracking-[0.2em] font-bold uppercase"
          >
            [ CARGANDO MÁS ESTRUCTURAS ]
          </span>
        </div>
      </section>
    </div>
  </main>
</MainLayout>

<script>
    const filterToggle = document.getElementById('filter-toggle');
    const sidebar = document.getElementById('catalog-sidebar');

    if (filterToggle && sidebar) {
        filterToggle.addEventListener('click', () => {
            sidebar.classList.toggle('hidden');
            sidebar.classList.toggle('flex');
        });
    }
</script>
