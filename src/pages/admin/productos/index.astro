---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getSupabase } from "../../../lib/supabaseServer";
// import MotionContainer from "../../../components/admin/MotionContainer"; // Eliminado por resiliencia de hidratación

const supabase = getSupabase(Astro.cookies);

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/admin/login");
}

// Obtener todos los productos con su categoría y primera imagen
const { data: products, error } = await supabase
  .from("products")
  .select(`
    id,
    name,
    price,
    status,
    is_customizable,
    categories ( name ),
    product_images ( storage_path )
  `)
  .order('created_at', { ascending: false });

// Formatear datos para la tabla
const formattedProducts = products?.map((p: any) => ({
  ...p,
  category_name: p.categories?.name || 'Sin Categoría',
  image: p.product_images?.[0]?.storage_path 
    ? `${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/products/${p.product_images[0].storage_path}`
    : null
})) || [];
---

<AdminLayout title="Catálogo" userEmail={user?.email}>
    <div class="page-header">
      <div class="header-text">
        <p>Curaduría y gestión de piezas exclusivas.</p>
      </div>
      <a href="/admin/productos/nuevo" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Nueva Pieza
      </a>
    </div>

    <div class="table-container">
      {error && (
        <div class="error-msg" style="padding: 2rem;">
          <h3 style="color: var(--danger); margin-top: 0; font-family: var(--font-heading); text-transform: uppercase;">Error de Sistema</h3>
          <p style="font-family: var(--font-mono); font-size: 0.85rem;">{error.message}</p>
        </div>
      )}
      
      {formattedProducts.length === 0 && !error ? (
        <div class="empty-state">
          <p>No se han encontrado piezas en el archivo.</p>
        </div>
      ) : (
        <table class="data-table">
          <thead>
            <tr>
              <th>Pieza</th>
              <th>Colección</th>
              <th>Inversión</th>
              <th>Estado</th>
              <th>Atelier</th>
              <th class="text-right">Gestión</th>
            </tr>
          </thead>
          <tbody>
            {formattedProducts.map((product, index) => (
              <tr style={`--delay: ${index * 0.05}s`} class="product-row">
                <td>
                  <div class="product-cell">
                    {product.image ? (
                      <div class="thumb-wrapper">
                        <img src={product.image} alt={product.name} class="product-thumb" />
                        {product.product_images?.length > 1 && (
                          <span class="image-count-badge">
                            +{product.product_images.length - 1}
                          </span>
                        )}
                      </div>
                    ) : (
                      <div class="product-thumb-placeholder">NO_IMG</div>
                    )}
                    <span class="product-name">{product.name}</span>
                  </div>
                </td>
                <td><span class="category-tag">{product.category_name}</span></td>
                <td><span class="price-tag">${product.price.toLocaleString()}</span></td>
                <td>
                  <span class={`status-badge ${product.status === 'active' ? 'active' : 'draft'}`}>
                    {product.status === 'active' ? 'Activo' : product.status === 'archived' ? 'Archivado' : 'Borrador'}
                  </span>
                </td>
                <td>
                  {product.is_customizable ? (
                    <span class="atelier-badge">Personalizable</span>
                  ) : (
                    <span class="text-muted" style="font-size: 0.75rem;">Estándar</span>
                  )}
                </td>
                <td class="actions-cell">
                  <a href={`/admin/productos/editar/${product.id}`} class="btn-icon" title="Editar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
</AdminLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .header-text p {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.95rem;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .table-container {
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--panel-border);
    background: var(--bg-dark);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .data-table th {
    padding: 1.5rem 2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-main);
    border-bottom: 1px solid var(--panel-border);
    font-weight: 700;
    font-family: var(--font-mono);
    background: transparent;
  }

  .data-table td {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--panel-border);
    vertical-align: middle;
    transition: all 0.3s ease;
  }

  .product-row {
    animation: fadeIn 0.5s ease forwards;
    animation-delay: var(--delay);
    opacity: 1;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .data-table tbody tr:hover td {
    background: var(--text-main);
    color: var(--bg-dark);
  }

  .data-table tbody tr:hover .category-tag,
  .data-table tbody tr:hover .price-tag,
  .data-table tbody tr:hover .product-name,
  .data-table tbody tr:hover .atelier-badge,
  .data-table tbody tr:hover .status-badge {
    color: var(--bg-dark);
    border-color: var(--bg-dark);
  }

  .data-table tbody tr:hover .btn-icon {
    color: var(--bg-dark);
    border-color: var(--bg-dark);
  }

  .product-cell {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .thumb-wrapper {
    width: 50px;
    height: 60px;
    border-radius: 0;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    background: transparent;
    position: relative;
  }

  .image-count-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--text-main);
    color: var(--bg-dark);
    font-size: 10px;
    font-family: var(--font-mono);
    padding: 2px 4px;
    border-radius: 0;
    font-weight: bold;
    border: none;
  }

  .product-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-row:hover .product-thumb {
    transform: scale(1.1);
  }

  .product-thumb-placeholder {
    width: 50px;
    height: 60px;
    border-radius: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    color: var(--text-muted);
    border: 1px solid var(--panel-border);
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
  }

  .product-name {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .category-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
  }

  .price-tag {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-main);
  }

  .status-badge {
    padding: 0.35rem 0.85rem;
    border-radius: 0;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--panel-border);
    font-family: var(--font-mono);
  }

  .status-badge.active {
    background: var(--primary);
    color: var(--text-main);
    border-color: var(--primary);
  }

  .status-badge.draft {
    background: transparent;
    color: var(--text-muted);
    border-style: dashed;
  }

  .atelier-badge {
    font-size: 0.7rem;
    color: var(--primary);
    border: 1px solid var(--primary);
    padding: 0.2rem 0.5rem;
    border-radius: 0;
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  .text-right {
    text-align: right;
  }

  .actions-cell {
    text-align: right;
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 0;
    background: transparent;
    color: var(--text-main);
    border: 1px solid var(--panel-border);
    transition: none;
  }

  .btn-icon:hover {
    background: var(--text-main);
    color: var(--bg-dark) !important;
    border-color: var(--text-main) !important;
  }

  .empty-state {
    padding: 5rem;
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 1.25rem;
    border-top: 1px dashed var(--panel-border);
  }

  .error-msg {
    color: var(--danger);
  }
</style>

