---
import MainLayout from "../../layouts/MainLayout.astro";
import { getSupabase } from "../../lib/supabaseServer";

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString();
    const password = data.get("password")?.toString();

    if (email && password) {
      const supabase = getSupabase(Astro.cookies);
      const { error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        errorMessage = error.message;
      } else {
        return Astro.redirect("/admin");
      }
    }
  } catch (err) {
    if (err instanceof Error) errorMessage = err.message;
  }
}
---

<MainLayout title="Atelier Access" description="Acceso al Panel de Administración">
  <div class="login-container">
    <div class="login-box">
      <div class="brand">
        <h2>Confeccion<span>Arte</span></h2>
        <div class="badge">Atelier Archive</div>
      </div>
      <h1>Acceso de Administración</h1>
      <p>Identifícate para gestionar el catálogo exclusivo.</p>

      {errorMessage && <div class="error-alert">{errorMessage}</div>}

      <form method="POST" class="login-form">
        <label>
          <span>Credencial de Acceso</span>
          <input type="email" name="email" required placeholder="atelier@confeccionarte.com" />
        </label>
        
        <label>
          <span>Firma Digital</span>
          <input type="password" name="password" required placeholder="••••••••" />
        </label>

        <button type="submit" class="btn-primary">Ingresar al Atelier</button>
      </form>
    </div>
  </div>
</MainLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap');

  .login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 2rem;
    background-color: #221010; /* Deep Oxblood */
    color: #f8f5f5; /* Paper White */
    font-family: 'Space Grotesk', sans-serif;
  }

  .login-box {
    width: 100%;
    max-width: 440px;
    padding: 4rem 3rem;
    text-align: center;
    border-radius: 0;
    background: #221010;
    border: 1px solid #f8f5f5;
  }

  .brand h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.05em;
    font-weight: 700;
  }

  .brand span {
    color: #f20d0d;
  }

  .brand .badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #221010;
    background: #f8f5f5;
    display: inline-block;
    padding: 0.2rem 0.5rem;
    margin-bottom: 3rem;
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
  }

  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  p {
    color: #8a8a8a;
    margin-bottom: 3rem;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    font-family: 'IBM Plex Mono', monospace;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: left;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  label span {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #f20d0d;
    font-family: 'IBM Plex Mono', monospace;
  }

  input {
    padding: 1.25rem;
    border-radius: 0;
    border: 1px solid #f8f5f5;
    background: transparent;
    color: #f8f5f5;
    font-size: 0.9rem;
    font-family: 'IBM Plex Mono', monospace;
    transition: none;
  }

  input:focus {
    outline: none;
    border-color: #f20d0d;
    background: #f8f5f5;
    color: #221010;
  }

  .btn-primary {
    margin-top: 1rem;
    padding: 1.25rem;
    background: #f20d0d;
    color: #f8f5f5;
    border: 1px solid #f20d0d;
    border-radius: 0;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-family: 'IBM Plex Mono', monospace;
    transition: none;
  }

  .btn-primary:hover {
    background: #221010;
    color: #f20d0d;
  }

  .error-alert {
    background: transparent;
    border: 1px solid #f20d0d;
    color: #f20d0d;
    padding: 1rem;
    border-radius: 0;
    margin-bottom: 2.5rem;
    font-size: 0.8rem;
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
  }
</style>

