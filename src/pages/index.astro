---
import MainLayout from "../layouts/MainLayout.astro";
import NavBar from "../components/NavBar.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import RandomProductsGrid from "../components/RandomProductsGrid.astro";
import FeaturedProducts from "../components/FeaturedProducts.astro";
import Manifesto from "../components/Manifesto.astro";
import ProcessConceptual from "../components/ProcessConceptual.astro";
import ConnectCTA from "../components/ConnectCTA.astro";

// Estrategia de Caché: SWR (Stale-While-Revalidate)
// La página se sirve instantáneamente desde el Edge de Vercel.
// Se revalida en segundo plano cada 60 segundos.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=600');
---

<MainLayout title="ConfeccionArte - Inicio">
	<NavBar />
	<main class="pt-[80px] flex-grow flex-col w-full overflow-x-hidden">
		<Hero />
		<Marquee />
		<RandomProductsGrid />
		<FeaturedProducts />
		<Manifesto />
		<ProcessConceptual />
		<ConnectCTA />
	</main>
</MainLayout>
